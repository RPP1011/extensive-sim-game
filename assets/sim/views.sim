// Compiler milestone â€” view declarations.
//
// See `docs/dsl/spec.md` Â§2.3 for the `view` surface and Â§9 D31 for the
// materialized storage hints. `@lazy` views emit an inline `pub fn` that
// mask / scoring / physics bodies can call directly; `@materialized`
// views emit a struct with a `get(args...)` + `fold_event(event, tick)`
// method pair, registered on `SimState.views`.
//
// The body lowering is mechanical â€” no type inference, no DSL
// polymorphism. Unknown stdlib methods error out at emit time; the
// legacy `crate::rules::*` fallback was retired in task 140 along with
// the last shim (`is_hostile`).

// -----------------------------------------------------------------------
// @lazy view is_hostile(a, b) â†’ bool
// -----------------------------------------------------------------------
// Pairwise species-level hostility. The body forwards to the
// `agents.is_hostile_to` stdlib primitive which wraps
// `CreatureType::is_hostile_to` (defined in the entities DSL) with a
// dead-slot short-circuit. No hand-written `crate::rules::*` shim â€” the
// mask / scoring / physics emitters all reach the matrix through this
// view.
@lazy
view is_hostile(a: Agent, b: Agent) -> bool {
  agents.is_hostile_to(a, b)
}

// -----------------------------------------------------------------------
// @lazy view is_stunned(a) -> bool
// -----------------------------------------------------------------------
// Timestamp-based stun predicate. Task 143 replaced the per-tick
// `stun_remaining_ticks` decrement with a stored absolute expiry tick;
// an agent is stunned while `world.tick < stun_expires_at_tick`. The
// zero-sentinel initial value falls through the predicate correctly
// because `world.tick >= 0` for every tick.
@lazy
view is_stunned(a: Agent) -> bool {
  world.tick < agents.stun_expires_at_tick(a)
}

// -----------------------------------------------------------------------
// @lazy view slow_factor(a) -> i16
// -----------------------------------------------------------------------
// Returns the active slow factor (q8 fixed-point) while the slow's
// expiry tick is still in the future, 0 once it has elapsed. Callers
// get a single read that already encodes the "is it still active?"
// check â€” no need to inspect `slow_expires_at_tick` separately.
@lazy
view slow_factor(a: Agent) -> i16 {
  if world.tick < agents.slow_expires_at_tick(a) {
    agents.slow_factor_q8(a)
  } else {
    0
  }
}

// -----------------------------------------------------------------------
// @materialized view threat_level(a, b) â†’ f32 â€” anchor-pattern decay.
// -----------------------------------------------------------------------
// Per-pair accumulating threat. Each `AgentAttacked` or
// `EffectDamageApplied` against `a` by `b` bumps `threat_level(a, b)`
// by 1; the stored value decays at 0.98^tick between events. Clamped
// to `[0.0, 1000.0]` so long-running simulations don't overflow.
//
// Storage: `pair_map<(AgentId, AgentId), f32>` â€” the default per spec
// Â§9 D31 when the view is keyed on a small-N Ă— small-N pair. At the
// spec's N=200K scale `pair_map` is infeasible for `(AgentId, AgentId)`;
// this view is intended for short-lived combat scenarios where the
// populated pair count is bounded. The compiler will reject the
// storage combination once the feasibility check lands (future task).
@materialized(on_event = [AgentAttacked, EffectDamageApplied], storage = pair_map)
@decay(rate = 0.98, per = tick)
view threat_level(a: Agent, b: Agent) -> f32 {
  initial: 0.0,
  on AgentAttacked { actor: b, target: a } { self += 1.0 }
  on EffectDamageApplied { actor: b, target: a } { self += 1.0 }
  clamp: [0.0, 1000.0],
}

// -----------------------------------------------------------------------
// @materialized view engaged_with(a) â†’ Agent â€” per-entity single slot.
// -----------------------------------------------------------------------
// Single-slot per-agent engagement partner. Task 139 retired the
// hand-written `ability::expire::tick_start` tentative-commit pass; the
// engine's `AgentMoved` / `AgentDied` cascade handler now decides who is
// engaged with whom and emits `EngagementCommitted` / `EngagementBroken`.
// The fold inserts both sides of a pairing on commit and removes both on
// break, so the map stays bidirectional without a cascade of paired
// events.
//
// Storage: `per_entity_topk(K=1)` â€” a `HashMap<AgentId, AgentId>` with
// one slot per key. K>1 (top-N threats etc.) is not supported yet.
@materialized(on_event = [EngagementCommitted, EngagementBroken], storage = per_entity_topk)
view engaged_with(a: Agent) -> Agent {
  initial: 0,
  on EngagementCommitted { actor: a, target: b } { self += 1 }
  on EngagementBroken { actor: a, former_target: b } { self += 1 }
}

// -----------------------------------------------------------------------
// @materialized view my_enemies(observer, attacker) â†’ f32 â€” memory-driven scoring.
// -----------------------------------------------------------------------
// Per-pair "has this attacker drawn blood on this observer?" flag stored
// as a saturating float. Each `AgentAttacked` event targeting `observer`
// by `attacker` folds +1.0 into the slot; `clamp: [0.0, 1.0]` pins the
// observable value at 1.0 once the first hit lands so repeated hits
// don't keep climbing. No `@decay` â€” grudges are for-life within a
// combat scenario (the runtime's HashMap is bounded by the populated
// pair count, same as `threat_level`).
//
// Consumed by scoring's Attack row as a hard retaliation bump â€” a
// wolf remembers who hurt it and prefers that specific human over
// an equivalent fresh target.
//
// Storage: `pair_map<(AgentId, AgentId), f32>` â€” same default as
// `threat_level`, per spec Â§9 D31.
@materialized(on_event = [AgentAttacked], storage = pair_map)
view my_enemies(observer: Agent, attacker: Agent) -> f32 {
  initial: 0.0,
  on AgentAttacked { actor: attacker, target: observer } { self += 1.0 }
  clamp: [0.0, 1.0],
}

// -----------------------------------------------------------------------
// @materialized view kin_fear(observer, dead_kin) â†’ f32 â€” rout mechanic.
// -----------------------------------------------------------------------
// Per-(observer, dead_kin) fear scalar. When a `FearSpread` event fires
// (emitted by the `fear_spread_on_death` physics rule once per nearby
// same-species kin at the moment of death), the observer's entry for
// that specific dead kin is bumped by +1.0 (the emitter hardcodes the
// fold amount; see `emit_fold_arm` in dsl_compiler). The anchor-pattern
// decay then pulls the value back toward 0 over time.
//
// `@decay(rate = 0.891, per = tick)` â‰ˆ 6-tick half-life (0.891^6 â‰ˆ
// 0.50). Task 173 shortened the half-life from ~15 ticks to ~6 ticks
// after the task-171 sweep showed 100% human wins across 50 seeds â€”
// with the 15-tick half-life, routs were permanent because kin_fear
// decayed slower than wolves could recover scoring priority. At the
// engine's 100 ms tick that's a ~0.6 s rout window â€” long enough to
// observably change Flee vs Attack scoring for a few ticks after a
// packmate dies, short enough that pack_focus (task 169, ~10-tick
// half-life) can pull survivors back when kin re-converge.
//
// Consumed by scoring's Flee row through the wildcard-slot helper
// `sum_for_first(observer, tick)` â€” every `@decay pair_map` view gets
// that helper auto-emitted (emit_view.rs:457+), so `view::kin_fear(self,
// _) > 0.3 : +0.5` on Flee sums decayed kin_fear across every recorded
// packmate-death pair for the scoring agent.
//
// Species scoping: the physics rule filters via `query.nearby_kin`, so
// every emitted `FearSpread` has matching-species (observer, dead_kin).
// The view itself is species-agnostic â€” "wolf sees wolf die â†’ fear",
// "human sees human die â†’ fear" both flow through the same fold.
//
// Storage: `pair_map<(AgentId, AgentId), (f32, u32)>` (the @decay
// variant stores (base, anchor_tick) per pair). Same bounded-population
// assumption as threat_level / my_enemies â€” pair count stays small in
// combat scenarios.
@materialized(on_event = [FearSpread], storage = pair_map)
@decay(rate = 0.891, per = tick)
view kin_fear(observer: Agent, dead_kin: Agent) -> f32 {
  initial: 0.0,
  on FearSpread { observer: observer, dead_kin: dead_kin } { self += 1.0 }
  clamp: [0.0, 10.0],
}

// -----------------------------------------------------------------------
// @materialized view pack_focus(observer, target) â†’ f32 â€” pack-hunt beacon.
// -----------------------------------------------------------------------
// Per-(observer, target) focus scalar. When a `PackAssist` event fires
// (emitted by the `pack_focus_on_engagement` physics rule once per
// nearby same-species kin at the moment a packmate commits an
// engagement), the observer's entry for that specific target is bumped
// by +1.0 (the emitter hardcodes the fold amount; see `emit_fold_arm`).
// The anchor-pattern decay pulls the value back toward 0 over time.
//
// `@decay(rate = 0.933, per = tick)` â‰ˆ 10-tick half-life (0.933^10 â‰ˆ
// 0.50). Shorter than kin_fear's 15-tick half-life because pack focus
// is a coordination nudge â€” once kin converge, the actual hits landing
// carry the grudge via threat_level / my_enemies. Longer decay would
// keep kin chasing a target that's already been dogpiled / fled /
// killed. At 100 ms ticks that's a ~1 s beacon window.
//
// Consumed by scoring's Attack row through the specific-slot form
// `view::pack_focus(self, target) > 0.5 : +0.4`. Specific-slot (not
// wildcard) is important â€” we want "observer's pack_focus on THIS
// candidate", not "observer's total pack_focus"; the latter would
// boost Attack against every target equally, defeating the focus.
//
// Species scoping: the physics rule filters via `query.nearby_kin`, so
// every emitted `PackAssist` has matching-species (observer, actor) by
// construction. The view itself is species-agnostic â€” "wolf sees wolf
// engage human â†’ pack focus on human" and "human sees human engage
// wolf â†’ pack focus on wolf" both flow through the same fold.
//
// Storage: `pair_map<(AgentId, AgentId), (f32, u32)>` (the @decay
// variant stores (base, anchor_tick) per pair). Same bounded-population
// assumption as kin_fear / threat_level / my_enemies â€” pair count stays
// small in combat scenarios.
@materialized(on_event = [PackAssist], storage = pair_map)
@decay(rate = 0.933, per = tick)
view pack_focus(observer: Agent, target: Agent) -> f32 {
  initial: 0.0,
  on PackAssist { observer: observer, target: target } { self += 1.0 }
  clamp: [0.0, 10.0],
}

// -----------------------------------------------------------------------
// @materialized view rally_boost(observer, wounded_kin) â†’ f32 â€” kin-wound rally.
// -----------------------------------------------------------------------
// Per-(observer, wounded_kin) rally scalar. When a `RallyCall` event
// fires (emitted by the `rally_on_wound` physics rule once per nearby
// same-species kin at the moment a packmate is wounded â€” damaged and
// dropped below half hp without dying), the observer's entry for that
// specific wounded kin is bumped by +1.0 (the emitter hardcodes the
// fold amount; see `emit_fold_arm` in dsl_compiler). The anchor-
// pattern decay then pulls the value back toward 0.
//
// `@decay(rate = 0.891, per = tick)` â‰ˆ 6-tick half-life (0.891^6 â‰ˆ
// 0.50). Matches `kin_fear`'s post-task-173 retuned decay so a
// "packmate hurt" signal fades on the same ~0.6 s timescale as
// "packmate died" â€” both are short-lived morale ticks that nudge a
// few ticks of behaviour without locking in permanent state.
//
// Symmetric to `kin_fear` in shape but inverted in effect:
//   kin_fear   : observer saw kin die  â†’ +Flee  (rout)
//   rally_boost: observer saw kin hurt â†’ +Attack (revenge / rally)
//
// Task constraint (per-pair keying instead of single-slot): the
// project's @decay storage currently supports only `pair_map` over
// 2-arg views; 1-arg @decay views are not a shape the compiler
// emits (see `emit_view.rs::emit_per_entity_topk1_struct` â€”
// `per_entity_topk(1)` storage does not support `@decay`). Keeping
// the signature `(observer, wounded_kin)` matches the `kin_fear`
// mirror exactly, and scoring uses the wildcard `_` slot to sum
// across every recorded wounded-kin pair for the observer â€” so the
// behavioural intent "any recent wound rallies me" is expressed at
// the scoring site, not the view shape.
//
// Consumed by scoring's Attack row through the wildcard-slot helper
// `sum_for_first(observer, tick)` â€” `view::rally_boost(self, _) > 0.3
// : +0.3`. The +0.3 bump is deliberately smaller than pack_focus's
// +0.4 and my_enemies' +0.4 so rally is meaningful without
// dominating when all three modifiers fire together.
//
// Species scoping: the physics rule filters via `query.nearby_kin`,
// so every emitted `RallyCall` has matching-species (observer,
// wounded_kin). The view itself is species-agnostic â€” "wolf sees
// wolf wounded â†’ rally", "human sees human wounded â†’ rally" both
// flow through the same fold.
//
// Storage: `pair_map<(AgentId, AgentId), (f32, u32)>` (the @decay
// variant stores (base, anchor_tick) per pair). Same bounded-
// population assumption as kin_fear â€” pair count stays small in
// combat scenarios.
@materialized(on_event = [RallyCall], storage = pair_map)
@decay(rate = 0.891, per = tick)
view rally_boost(observer: Agent, wounded_kin: Agent) -> f32 {
  initial: 0.0,
  on RallyCall { observer: observer, wounded_kin: wounded_kin } { self += 1.0 }
  clamp: [0.0, 10.0],
}
