// Runtime-prelude body (Stream B prelude module).
//
// Every per-kind helper packs typed args into the fixed 10-word
// EventRecord layout the CPU drain expects:
//   [0]      kind
//   [1]      tick
//   [2..10]  payload[0..8]
//
// Returns the slot index the record landed in, or 0xFFFFFFFFu on
// overflow. Silent drop on full ring — the CPU drain sees tail > cap
// and flips the overflow flag. We deliberately don't retry / spin
// because that would serialise emitters.

fn gpu_emit_event(kind: u32, tick: u32,
p0: u32, p1: u32, p2: u32, p3: u32,
p4: u32, p5: u32, p6: u32, p7: u32) -> u32 {
let idx = atomicAdd(&event_ring_tail, 1u);
if (idx >= EVENT_RING_CAP) {
return 0xFFFFFFFFu;
}
let base = idx * RECORD_U32_STRIDE;
event_ring_records[base + 0u] = kind;
event_ring_records[base + 1u] = tick;
event_ring_records[base + 2u] = p0;
event_ring_records[base + 3u] = p1;
event_ring_records[base + 4u] = p2;
event_ring_records[base + 5u] = p3;
event_ring_records[base + 6u] = p4;
event_ring_records[base + 7u] = p5;
event_ring_records[base + 8u] = p6;
event_ring_records[base + 9u] = p7;
return idx;
}

