@compute @workgroup_size(64)
fn cs_apply_actions(@builtin(global_invocation_id) gid: vec3<u32>) {
let slot = gid.x;
if (slot >= cfg.agent_cap) { return; }
if (agent_alive(slot) == 0u) { return; }

let self_id = slot + 1u;
let action = scoring_action(slot);
let tgt_slot_raw = scoring_target(slot);
let tick = sim_cfg_tick();

// ATTACK — only action that mutates state in this kernel.
if (action == ACTION_ATTACK) {
if (tgt_slot_raw == NO_TARGET) { return; }
let t_slot = tgt_slot_raw;
if (t_slot >= cfg.agent_cap) { return; }
if (agent_alive(t_slot) == 0u) { return; }
let tgt_id = t_slot + 1u;

// Range check (defence in depth — mask kernel already gates).
let self_pos = agent_pos(slot);
let target_pos = agent_pos(t_slot);
let delta = self_pos - target_pos;
let dist = sqrt(delta.x * delta.x + delta.y * delta.y + delta.z * delta.z);
let range = sim_cfg_attack_range();
if (dist > range) { return; }

let dmg = agent_attack_damage(slot);
let old_hp = agent_hp(t_slot);
let new_hp = max(old_hp - dmg, 0.0);
set_agent_hp(t_slot, new_hp);
let _atk_idx = gpu_emit_agent_attacked(self_id, tgt_id, dmg, tick);
if (new_hp <= 0.0) {
set_agent_dead(t_slot);
let _die_idx = gpu_emit_agent_died(tgt_id, tick);
}
return;
}

// HOLD / MOVE / FLEE / CAST / Eat / Drink / Rest:
// - HOLD/MOVE/FLEE: no state mutation; movement kernel owns pos.
// - CAST: handled by physics fixed-point via cascade events.
// - Eat/Drink/Rest: pending hunger/thirst/fatigue fields on
//   GpuAgentSlot. Skip emission for now (pre-T16 also stubbed).
}
