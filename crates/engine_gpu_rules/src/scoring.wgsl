fn eval_predicate(pred: PredicateDescriptor, agent_slot: u32, target_slot: u32) -> bool {
    switch (pred.kind) {
        case 0u: { return true; }
        case 1u: {
            let lhs = read_field(agent_slot, target_slot, pred.field_id);
            let rhs = f32_from_u32_bits(pred.payload0);
            return compare_scalar(pred.op, lhs, rhs);
        }
        case 7u: {
            let lhs = eval_view_call(agent_slot, target_slot, pred);
            let rhs = f32_from_u32_bits(pred.payload0);
            return compare_scalar(pred.op, lhs, rhs);
        }
        default: { return false; }
    }
}

fn score_entry(entry_idx: u32, agent_slot: u32, target_slot: u32) -> f32 {
    let e = scoring_table[entry_idx];
    var score: f32 = e.base;
    let n = min(e.modifier_count, 16u);
    for (var i: u32 = 0u; i < n; i = i + 1u) {
        let row = e.modifiers[i];
        if (row.predicate.kind == KIND_VIEW_GRADIENT) {
            let v = eval_view_call(agent_slot, target_slot, row.predicate);
            let is_finite_v = (v == v) && (v != bitcast<f32>(0x7F800000u)) && (v != bitcast<f32>(0xFF800000u));
            if (is_finite_v) {
                score = score + v * row.delta;
            }
        } else {
            if (eval_predicate(row.predicate, agent_slot, target_slot)) {
                score = score + row.delta;
            }
        }
    }
    return score;
}

@compute @workgroup_size(64)
fn cs_scoring(@builtin(global_invocation_id) gid: vec3<u32>) {
    let agent_slot = gid.x;
    let n = arrayLength(&agent_data);
    if (agent_slot >= n) { return; }
    if (!alive_bit(agent_slot)) {
        scoring_out[agent_slot].chosen_action = 0u;
        scoring_out[agent_slot].chosen_target = NO_TARGET;
        scoring_out[agent_slot].best_score_bits = 0u;
        return;
    }

    // Sentinel: no valid best yet.
    var best_score: f32 = 0.0;
    var best_action: u32 = 0u;
    var best_target: u32 = NO_TARGET;
    var found_any: bool = false;

    for (var e_idx: u32 = 0u; e_idx < cfg.num_entries; e_idx = e_idx + 1u) {
        let action_head = scoring_table[e_idx].action_head;
        let mask_idx = action_head_to_mask_idx(action_head);
        if (mask_idx == 0xFFFFu) { continue; }
        if (!mask_bit(mask_idx, agent_slot)) { continue; }

        if (action_head_is_target_bound(action_head)) {
            // Walk K=32 spatial-within candidates in ascending raw-id order.
            let kin_count = spatial_within[agent_slot].count;
            for (var i: u32 = 0u; i < kin_count; i = i + 1u) {
                let raw_id = spatial_within[agent_slot].ids[i];
                if (raw_id == 0u || raw_id == 0xFFFFFFFFu) { continue; }
                let t = raw_id - 1u;
                if (t == agent_slot) { continue; }
                if (!alive_bit(t)) { continue; }
                let radius = select(
                    cfg.movement_max_move_radius,
                    sim_cfg.attack_range,
                    action_head == 3u
                );
                let d = vec3_distance(agent_data[agent_slot].pos, agent_data[t].pos);
                if (d > radius) { continue; }
                if (action_head == 3u) {
                    let self_ct = agent_data[agent_slot].creature_type;
                    let tgt_ct = agent_data[t].creature_type;
                    if (!is_hostile_ct(self_ct, tgt_ct)) { continue; }
                }

                let s = score_entry(e_idx, agent_slot, t);
                if (!found_any || s > best_score) {
                    best_score = s;
                    best_action = action_head;
                    best_target = t;
                    found_any = true;
                }
            }
        } else {
            let s = score_entry(e_idx, agent_slot, NO_TARGET);
            if (!found_any || s > best_score) {
                best_score = s;
                best_action = action_head;
                best_target = NO_TARGET;
                found_any = true;
            }
        }
    }

    if (!found_any) {
        best_action = 0u;
        best_target = NO_TARGET;
        best_score = 0.0;
    }
    scoring_out[agent_slot].chosen_action = best_action;
    scoring_out[agent_slot].chosen_target = best_target;
    scoring_out[agent_slot].best_score_bits = bitcast<u32>(best_score);
}

fn is_hostile_ct(a: u32, b: u32) -> bool {
    // Human<->Wolf, Human<->Dragon, Wolf<->Deer, Wolf<->Dragon, Deer<->Dragon.
    if (a == 0u && b == 1u) { return true; }
    if (a == 1u && b == 0u) { return true; }
    if (a == 0u && b == 3u) { return true; }
    if (a == 3u && b == 0u) { return true; }
    if (a == 1u && b == 2u) { return true; }
    if (a == 2u && b == 1u) { return true; }
    if (a == 1u && b == 3u) { return true; }
    if (a == 3u && b == 1u) { return true; }
    if (a == 2u && b == 3u) { return true; }
    if (a == 3u && b == 2u) { return true; }
    return false;
}
