fn vec3_distance(a: Vec3f32, b: Vec3f32) -> f32 {
    let dx = a.x - b.x;
    let dy = a.y - b.y;
    let dz = a.z - b.z;
    return sqrt(dx*dx + dy*dy + dz*dz);
}

fn mask_bit(mask_idx: u32, slot: u32) -> bool {
    let base = mask_idx * cfg.num_mask_words;
    let word = base + (slot / 32u);
    let bit = slot % 32u;
    return (mask_bitmaps[word] & (1u << bit)) != 0u;
}

fn action_head_to_mask_idx(ah: u32) -> u32 {
    switch (ah) {
        case 0u: { return 2u; }
        case 1u: { return 1u; }
        case 2u: { return 3u; }
        case 3u: { return 0u; }
        case 7u: { return 4u; }
        case 8u: { return 5u; }
        case 9u: { return 6u; }
        default: { return 0xFFFFu; }
    }
}

fn action_head_is_target_bound(ah: u32) -> bool {
    return ah == 1u || ah == 3u;
}

fn compare_scalar(op: u32, lhs: f32, rhs: f32) -> bool {
    // NaN short-circuits to false, matching IEEE + CPU semantics.
    if (lhs != lhs || rhs != rhs) { return false; }
    switch (op) {
        case 0u: { return lhs < rhs; }
        case 1u: { return lhs <= rhs; }
        case 2u: { return lhs == rhs; }
        case 3u: { return lhs >= rhs; }
        case 4u: { return lhs > rhs; }
        case 5u: { return lhs != rhs; }
        default: { return false; }
    }
}

fn f32_from_u32_bits(bits: u32) -> f32 {
    return bitcast<f32>(bits);
}

fn read_field(agent_slot: u32, target_slot: u32, field_id: u32) -> f32 {
    // Target-side range 0x4000..0x8000.
    if (field_id >= TARGET_FIELD_BASE && field_id < TARGET_FIELD_END) {
        if (target_slot == NO_TARGET) { return bitcast<f32>(0x7FC00000u); }
        let tf = field_id - TARGET_FIELD_BASE;
        let t = agent_data[target_slot];
        switch (tf) {
            case 0u: { return t.hp; }
            case 1u: { return t.max_hp; }
            case 2u: { return t.hp_pct; }
            case 3u: { return t.shield_hp; }
            default: { return bitcast<f32>(0x7FC00000u); }
        }
    }

    let a = agent_data[agent_slot];
    switch (field_id) {
        case 0u: { return a.hp; }
        case 1u: { return a.max_hp; }
        case 2u: { return a.hp_pct; }
        case 3u: { return a.shield_hp; }
        case 4u: { return a.attack_range; }
        case 5u: { return a.hunger; }
        case 6u: { return a.thirst; }
        case 7u: { return a.fatigue; }
        case 8u: { return 0.0; }
        case 9u: { return 0.0; }
        case 10u: { return 0.0; }
        case 11u: { return 0.0; }
        case 12u: { return 0.0; }
        default: { return bitcast<f32>(0x7FC00000u); }
    }
}

const ARG_SELF: u32 = 0u;
const ARG_TARGET: u32 = 1u;
const ARG_WILDCARD: u32 = 0xFEu;
const ARG_NONE: u32 = 0xFFu;

fn resolve_view_arg(code: u32, agent_slot: u32, target_slot: u32) -> u32 {
    if (code == ARG_SELF) { return agent_slot; }
    if (code == ARG_TARGET) { return target_slot; }
    return NO_TARGET;
}

fn eval_view_call(agent_slot: u32, target_slot: u32, pred: PredicateDescriptor) -> f32 {
    let slot0 = (pred.payload1) & 0xFFu;
    let slot1 = (pred.payload1 >> 8u) & 0xFFu;
    let view_id = pred.field_id;
    let a = resolve_view_arg(slot0, agent_slot, target_slot);
    if (a == NO_TARGET) { return bitcast<f32>(0x7FC00000u); }
    switch (view_id) {
        case 0u: {
            // VIEW `threat_level`
            if (slot1 == ARG_WILDCARD) {
                return view_threat_level_sum(a, sim_cfg.tick);
            }
            let b = resolve_view_arg(slot1, agent_slot, target_slot);
            if (b == NO_TARGET) { return bitcast<f32>(0x7FC00000u); }
            return view_threat_level_get(a, b, sim_cfg.tick);
        }
        case 1u: {
            // VIEW `my_enemies`
            if (slot1 == ARG_WILDCARD) {
                return view_my_enemies_sum(a);
            }
            let b = resolve_view_arg(slot1, agent_slot, target_slot);
            if (b == NO_TARGET) { return bitcast<f32>(0x7FC00000u); }
            return view_my_enemies_get(a, b);
        }
        case 2u: {
            // VIEW `kin_fear`
            if (slot1 == ARG_WILDCARD) {
                return view_kin_fear_sum(a, sim_cfg.tick);
            }
            let b = resolve_view_arg(slot1, agent_slot, target_slot);
            if (b == NO_TARGET) { return bitcast<f32>(0x7FC00000u); }
            return view_kin_fear_get(a, b, sim_cfg.tick);
        }
        case 3u: {
            // VIEW `pack_focus`
            if (slot1 == ARG_WILDCARD) {
                return view_pack_focus_sum(a, sim_cfg.tick);
            }
            let b = resolve_view_arg(slot1, agent_slot, target_slot);
            if (b == NO_TARGET) { return bitcast<f32>(0x7FC00000u); }
            return view_pack_focus_get(a, b, sim_cfg.tick);
        }
        case 4u: {
            // VIEW `rally_boost`
            if (slot1 == ARG_WILDCARD) {
                return view_rally_boost_sum(a, sim_cfg.tick);
            }
            let b = resolve_view_arg(slot1, agent_slot, target_slot);
            if (b == NO_TARGET) { return bitcast<f32>(0x7FC00000u); }
            return view_rally_boost_get(a, b, sim_cfg.tick);
