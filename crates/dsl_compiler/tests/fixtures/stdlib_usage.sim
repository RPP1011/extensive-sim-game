// Exercises Rust-backed stdlib primitives and typed namespaces.
// `distance`, `rng.uniform`, `world.tick`, `query.nearby_agents` should
// all resolve to structured stdlib nodes (BuiltinCall / NamespaceCall /
// NamespaceField) rather than UnresolvedCall or loose Field/Namespace.
@lazy
view should_act(self: Agent, target: Agent) -> bool {
  distance(self.pos, target.pos) < 10.0
  && rng.uniform(0.0, 1.0) > 0.5
  && world.tick % 100 == 0
  && count(a in query.nearby_agents(self.pos, 20.0) where a.alive) > 0
}
