// Scoring with gradient modifiers (`<expr> per_unit <delta>`, spec §3.4).
// The gradient form is a sibling sum term: the scoring emitter lifts each
// `per_unit` into a KIND_GRADIENT modifier row with `score += expr * delta`
// semantics. Mixed with the existing boolean `if` form so the flattener
// recognises both.
scoring {
  Attack(t) = 0.5
            + (if self.hp_pct < 0.3 { 0.4 } else { 0.0 })
            + threat_level(self, t) per_unit 0.02
            + (1.0 - t.hp_pct) per_unit 0.6
}
