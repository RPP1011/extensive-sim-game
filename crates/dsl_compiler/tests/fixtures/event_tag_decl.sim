// An event_tag contract + an event that claims it. The emitter weaves
// this event into any `physics on @harmful { ... }` handler's
// per-kind dispatcher at compile time — no runtime tag lookup.
event_tag Harmful { actor: AgentId, target: AgentId }

@replayable @harmful event AgentAttacked {
  actor: AgentId,
  target: AgentId,
  damage: f32,
}
