// For-loop with a `where` filter clause over a bounded stdlib iterator.
// `voxel.neighbors_above(p)` is a stdlib 1-hop method (§1.2) that returns
// a `SmallVec<Vec3, 6>` — capped, GPU-emittable, one of the approved
// iteration sources for physics bodies (compiler/spec.md §1.2).
physics stone_settle @phase(event) @terminating_in(1) {
  on VoxelChanged{pos: p} {
    for q in voxel.neighbors_above(p) where q.kind == Stone {
      emit VoxelSettled { pos: q }
    }
  }
}
