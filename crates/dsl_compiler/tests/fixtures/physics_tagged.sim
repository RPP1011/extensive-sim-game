// Physics rule that fires on every event claiming `@harmful`. The
// dispatcher expands this handler into each applicable event's per-kind
// dispatcher at compile time.
event_tag Harmful { actor: AgentId, target: AgentId }

@replayable @harmful event AgentAttacked {
  actor: AgentId,
  target: AgentId,
  damage: f32,
}

physics enforce_harm @phase(event) {
  on @harmful { target: t } where t != 0 {
    agents.set_hp(t, 0.0)
  }
}
