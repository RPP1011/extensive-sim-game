// Scoring-coverage fixture — one row per MicroKind in `mask::MicroKind::ALL`.
// Shipped by task 141 so the full 18-micro scoring table round-trips
// through the emitter. Every row uses the milestone-5 supported RHS
// grammar: literal base + optional `if self.<field> <op> <lit> { <lit> }
// else { 0.0 }` modifiers. Heads that need a target parameter (Attack)
// are declared positional to match the engine's action-head shape.

scoring {
  // Movement
  Hold       = 0.1
  MoveToward = 0.3
  Flee       = 0.0 + (if self.hp_pct < 0.3 { 0.6 } else { 0.0 })

  // Combat
  Attack(t)  = 0.0 + (if self.hp_pct >= 0.5 { 0.5 } else { 0.0 })
  Cast       = 0.0
  UseItem    = 0.0

  // Resource
  Harvest    = 0.0
  Eat        = 0.0 + (if self.hp_pct < 0.3 { 0.8 } else { 0.0 })
  Drink      = 0.0
  Rest       = 0.0

  // Construction
  PlaceTile    = 0.0
  PlaceVoxel   = 0.0
  HarvestVoxel = 0.0

  // Social
  Converse   = 0.0
  ShareStory = 0.0

  // Info push + pull
  Communicate = 0.0
  Ask         = 0.0

  // Memory
  Remember = 0.0
}
