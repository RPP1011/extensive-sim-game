// Tier 1: Single instant shield — varying amounts and durations

ability Ward {
    target: ally, range: 4.0
    cooldown: 6s, cast: 200ms
    hint: defense

    shield 25 for 4s
}

ability Barrier {
    target: self
    cooldown: 12s, cast: 200ms
    hint: defense

    shield 55 for 5s
}

ability IronShield {
    target: ally, range: 3.0
    cooldown: 8s, cast: 200ms
    hint: defense

    shield 40 for 4s
}
