class Sailor {
    stat_growth: +1 attack, +2 speed, +1 defense, +1 max_hp per level

    tags: naval, navigation, fishing, weather, seafaring

    scaling hp_percent {
        when hp_percent > 50: +10% speed
        always: +5% defense
    }

    abilities {
        level 1: sea_legs "Never suffer penalties from rough terrain or weather"
        level 5: read_the_wind "Predict storms and weather changes days in advance"
        level 10: expert_fisher "Provide food for the party from any body of water"
        level 20: captains_command "Your ship moves faster and survives storms that would sink others"
        level 40: call_the_tide "Command the sea itself; summon floods, fog, or calm waters at will"
    }

    requirements: level 1
}
